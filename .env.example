# DalioBot Environment Variables
# Copy this to .env and fill in your keys

# Alpaca Brokerage (https://alpaca.markets — free account)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# FRED Economic Data (https://fred.stlouisfed.org/docs/api/api_key.html — free)
FRED_API_KEY=your_fred_api_key_here

# n8n Automation (your Render instance)
N8N_API_URL=https://n8n-nc63.onrender.com/
N8N_API_KEY=your_n8n_api_key_here
N8N_WEBHOOK_SECRET=your_webhook_secret_here

# DalioBot API URL (set after deploying to Render)
DALIOBOT_API_URL=https://daliobot-api.onrender.com
